generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WordAttemptStatus {
  NotAttempted
  InProgress
  Mastered
}

enum GradeLevel {
  K
  GRADE_1
  GRADE_2
  GRADE_3
  GRADE_4
  GRADE_5
}

enum CurriculumSubject {
  ELA
  MATH
}

model GameMode {
  id          String @id @default(cuid())
  title       String
  slug        String @unique
  description String
  metadata    Json   @default("{}")
}

model Student {
  id               String @id @default(cuid())
  username         String @unique
  pin              String
  grade            GradeLevel @default(K)
  assignedSubjects CurriculumSubject[] @default([])
  createdAt        DateTime @default(now())

  wordAttempts WordAttempt[]
  quizAttempts QuizAttempt[]
}

model WordAttempt {
  id                 String            @id @default(cuid())
  studentId          String
  attemptCount       Int
  status             WordAttemptStatus @default(NotAttempted)
  wordText           String
  averageAttemptInMs Int

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, wordText])
}

model QuizAttempt {
  id             String            @id @default(cuid())
  studentId      String
  subject        CurriculumSubject
  grade          GradeLevel
  standardCode   String
  quizId         String
  correctAnswers Int
  questionCount  Int
  durationMs     Int
  completedAt    DateTime          @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, subject, grade])
}
